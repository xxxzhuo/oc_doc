# 暗标竞标系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ⚠️ 安全提示：生产环境必须使用强随机密钥！
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"

# JWT 密钥 (32 字节十六进制)
SECRET_KEY=your-secret-key-here-change-in-production

# 报价加密密钥 (64 字符十六进制 = 32 字节)
ENCRYPTION_KEY=your-encryption-key-here-64-chars-hex

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./bidding.db
# 生产环境使用 PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bidding

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# CORS 允许的来源 (多个用逗号分隔)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# 速率限制 (登录接口)
RATE_LIMIT_PER_MINUTE=5
